{
  "name": "@makemyclip/editor",
  "version": "0.0.1",
  "description": "AI-native video editor — talk to make video. Trim, zoom, caption, and assemble clips from any AI agent. Delivered as an MCP server + agent skill.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "video-editing",
    "ffmpeg",
    "claude",
    "cursor",
    "agent-skill",
    "ai-video",
    "typescript"
  ],
  "homepage": "https://github.com/MakeMyClip/editor",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MakeMyClip/editor.git"
  },
  "bugs": {
    "url": "https://github.com/MakeMyClip/editor/issues"
  },
  "license": "MIT",
  "author": "MakeMyClip",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "clip": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "SKILL.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "lint": "echo \"lint not configured yet — see AGENTS.md\" && exit 0",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "execa": "^9.6.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
